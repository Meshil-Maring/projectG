generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum Role {
  ADMIN
  EDITOR
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(EDITOR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model SiteSettings {
  id               String   @id @default("main")
  heroImageUrl     String   @default("")
  heroTitle        String   @default("")
  heroDescription  String   @default("")
  storyTitle       String   @default("")
  storyDescription String   @default("")
  storyThumbnail   String   @default("")
  storyYoutubeId   String   @default("")
  storyVideoUrl    String   @default("")
  storyDuration    String   @default("")
  updatedAt        DateTime @updatedAt

  @@map("site_settings")
}

model HomeVideo {
  id          Int     @id @default(autoincrement())
  title       String
  description String
  thumbnail   String
  youtubeId   String  @default("")
  videoUrl    String  @default("")
  duration    String
  order       Int     @default(0)

  @@map("home_videos")
}

model GalleryPhoto {
  id          Int    @id @default(autoincrement())
  src         String
  alt         String
  description String
  order       Int    @default(0)

  @@map("gallery_photos")
}

model ImpactStat {
  id      Int    @id @default(autoincrement())
  iconKey String
  value   String
  label   String
  order   Int    @default(0)

  @@map("impact_stats")
}

model Story {
  id    Int    @id @default(autoincrement())
  image String
  quote String
  name  String
  role  String
  order Int    @default(0)

  @@map("stories")
}

model Activity {
  id       Int    @id @default(autoincrement())
  group    String
  title    String
  desc     String
  imageUrl String @default("")
  order    Int    @default(0)

  @@map("activities")
}

model BoardMember {
  id    Int    @id @default(autoincrement())
  name  String
  role  String
  badge String
  color String
  order Int    @default(0)

  @@map("board_members")
}

model TeamMember {
  id    Int    @id @default(autoincrement())
  name  String
  role  String
  color String
  order Int    @default(0)

  @@map("team_members")
}

model Notice {
  id       Int    @id @default(autoincrement())
  title    String
  category String
  date     String
  summary  String
  body     String
  order    Int    @default(0)

  @@map("notices")
}

model Page {
  id        String    @id @default(cuid())
  slug      String    @unique
  title     String
  sections  Section[]
  updatedAt DateTime  @updatedAt

  @@map("pages")
}

model Section {
  id      Int     @id @default(autoincrement())
  pageId  String
  page    Page    @relation(fields: [pageId], references: [id], onDelete: Cascade)
  type    String
  enabled Boolean @default(true)
  order   Int     @default(0)
  data    Json

  @@index([pageId, order])
  @@map("sections")
}

model Donation {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  section   String
  amount    Int
  message   String?
  createdAt DateTime @default(now())

  @@map("donations")
}

model RawPhoto {
  id         Int      @id @default(autoincrement())
  section    String
  url        String
  filename   String
  caption    String   @default("")
  uploadedAt DateTime @default(now())

  @@index([section])
  @@map("raw_photos")
}

model WhgGroup {
  id          Int        @id @default(autoincrement())
  name        String
  description String     @default("")
  theme       String     @default("")
  themeColor  String     @default("")
  keyPrefix   String
  order       Int        @default(0)
  createdAt   DateTime   @default(now())
  images      WhgImage[]

  @@map("whg_groups")
}

model WhgImage {
  id          String   @id @default(cuid())
  groupId     Int
  group       WhgGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  key         String   @unique
  name        String   @default("")
  description String   @default("")
  uploadedAt  DateTime @default(now())

  @@index([groupId])
  @@map("whg_images")
}

model LacGroup {
  id          Int        @id @default(autoincrement())
  name        String
  description String     @default("")
  theme       String     @default("")
  themeColor  String     @default("")
  keyPrefix   String
  order       Int        @default(0)
  createdAt   DateTime   @default(now())
  images      LacImage[]

  @@map("lac_groups")
}

model LacImage {
  id          String   @id @default(cuid())
  groupId     Int
  group       LacGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  key         String   @unique
  name        String   @default("")
  description String   @default("")
  uploadedAt  DateTime @default(now())

  @@index([groupId])
  @@map("lac_images")
}

model HrdsGroup {
  id          Int         @id @default(autoincrement())
  name        String
  description String      @default("")
  theme       String      @default("")
  themeColor  String      @default("")
  keyPrefix   String
  order       Int         @default(0)
  createdAt   DateTime    @default(now())
  images      HrdsImage[]

  @@map("hrds_groups")
}

model HrdsImage {
  id          String    @id @default(cuid())
  groupId     Int
  group       HrdsGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  key         String    @unique
  name        String    @default("")
  description String    @default("")
  uploadedAt  DateTime  @default(now())

  @@index([groupId])
  @@map("hrds_images")
}

model CwgGroup {
  id          Int        @id @default(autoincrement())
  name        String
  description String     @default("")
  theme       String     @default("")
  themeColor  String     @default("")
  keyPrefix   String
  order       Int        @default(0)
  createdAt   DateTime   @default(now())
  images      CwgImage[]

  @@map("cwg_groups")
}

model CwgImage {
  id          String   @id @default(cuid())
  groupId     Int
  group       CwgGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  key         String   @unique
  name        String   @default("")
  description String   @default("")
  uploadedAt  DateTime @default(now())

  @@index([groupId])
  @@map("cwg_images")
}

model FsedsGroup {
  id          Int          @id @default(autoincrement())
  name        String
  description String       @default("")
  theme       String       @default("")
  themeColor  String       @default("")
  keyPrefix   String
  order       Int          @default(0)
  createdAt   DateTime     @default(now())
  images      FsedsImage[]

  @@map("fseds_groups")
}

model FsedsImage {
  id          String     @id @default(cuid())
  groupId     Int
  group       FsedsGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  key         String     @unique
  name        String     @default("")
  description String     @default("")
  uploadedAt  DateTime   @default(now())

  @@index([groupId])
  @@map("fseds_images")
}
